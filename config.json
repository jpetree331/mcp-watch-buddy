{
  "default_window": null,
  "persona": "curious, dry-humored, observant — you notice things others miss",
  "fps": 10,
  "bundle_interval_seconds": 1,
  "change_threshold": 25,
  "min_contour_area": 500,
  "atlas": {
    "enabled": true,
    "gutter": 8,
    "max_tiles": 12,
    "max_width": 1024
  },
  "crop_downscale": {
    "enabled": false,
    "min_dimension": 400,
    "scale": 0.6,
    "exclude_zones": ["chat"]
  },
  "ears": {
    "enabled": true,
    "chunk_seconds": 12,
    "silence_rms": 0.006,
    "endpoint": "https://vonkaiser-audiodojo.chutes.ai/stt/whisper",
    "language": null,
    "keep_minutes": 240,
    "log_to_file": true
  },
  "screen_zones": {
    "gameplay": {"x": 0, "y": 0, "width": 1000, "height": 680},
    "chat": {"x": 1000, "y": 0, "width": 280, "height": 720},
    "hud": {"x": 0, "y": 680, "width": 1000, "height": 40}
  }
}
